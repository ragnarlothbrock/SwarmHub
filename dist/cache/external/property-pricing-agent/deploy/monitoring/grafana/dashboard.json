{
  "annotations": { "list": [] },
  "description": "AI Real Estate Assistant — API, Cache, Latency, and Health Overview",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "title": "P95 Latency by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "request_latency_p95_ms",
          "legendFormat": "{{endpoint_group}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "thresholds": {
        "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 2000 },
          { "color": "red", "value": 8000 }
        ]
      }
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "cache_hit_rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "green", "value": 0.6 }
            ]
          }
        }
      }
    },
    {
      "title": "Cache Size",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "cache_size",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Application Health",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "app_health_status",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Unhealthy", "color": "red" }, "1": { "text": "Degraded", "color": "yellow" }, "2": { "text": "Healthy", "color": "green" } } }
          ]
        }
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "app_uptime_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Vector Store Documents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "vector_store_documents",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Process Memory (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "process_memory_mb",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ai-real-estate", "production"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "AI Real Estate Assistant — Overview",
  "uid": "ai-rea-estate-overview",
  "version": 1
}
