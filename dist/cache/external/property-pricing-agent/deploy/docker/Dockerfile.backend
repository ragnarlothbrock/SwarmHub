FROM python:3.12-slim-bookworm
WORKDIR /app
# Install dependencies with pinned versions for reproducibility
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        curl \
        git \
    && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*
# Install uv for faster Python package management
COPY --from=ghcr.io/astral-sh/uv:0.10.0 /uv /usr/local/bin/uv
COPY apps/api/requirements.txt .
# Use uv to install dependencies (much faster than pip)
RUN uv pip install --system -r requirements.txt && \
    uv cache clean
COPY apps/api .
# Create non-root user for security (Task #64)
RUN groupadd -r appuser && useradd -r -g appuser -d /app -s /sbin/nologin appuser && \
    chown -R appuser:appuser /app
USER appuser
# Pre-bundle the default fastembed embedding model so the container
# boots without needing outbound HTTPS to HuggingFace at startup.
# The default cache dir is $HOME/.cache/fastembed (= /app/.cache/fastembed,
# since appuser's home is /app). Without this, the smoke-test in CI
# (run 27007739447 for v5.0.7) failed because the CI runner blocks
# HuggingFace egress. The download happens at build time when pip
# already has internet for `uv pip install`, so the cost is ~30s of
# build time and ~33 MB of image size.
#
# v5.0.8: switched to a Python helper (apps/api/prebundle_fastembed.py)
# that retries the download with exponential backoff (8 attempts, 5-60s
# delays, ~5 min worst case). The previous one-liner only retried 3x
# internally, and HuggingFace's CloudFront was returning HTTP 429 to the
# CI runner — enough to push the smoke test past its 40s window.
#
# The script lives in apps/api/ (not deploy/docker/) because the root
# .dockerignore excludes the deploy/ directory from the build context.
# It stays in /tmp after the run (~3KB) — the `&& rm` cleanup was
# removed because the appuser doesn't own the file in /tmp and gets
# "Operation not permitted" on removal.
COPY apps/api/prebundle_fastembed.py /tmp/prebundle_fastembed.py
RUN python /tmp/prebundle_fastembed.py
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app
EXPOSE ${PORT:-8000}
HEALTHCHECK CMD curl --fail http://localhost:${PORT:-8000}/health || exit 1
CMD python -m uvicorn api.main:app --host 0.0.0.0 --port ${PORT:-8000}
