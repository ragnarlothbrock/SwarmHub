# Docker Compose Environment Variables
# Copy to .env and configure for your deployment
#
# Documentation Legend:
#   Container:  Which service uses this variable
#   Required:  Whether the variable is required
#   Default:  Built-in default value
#   Security: Notes about sensitive values
#
# =============================================================================
# CORE CONFIGURATION
# =============================================================================

# COMPOSE_PROJECT_NAME - Docker Compose project name
#   Container: All services
#   Default:  real-estate-assistant
COMPOSE_PROJECT_NAME=real-estate-assistant

# ENVIRONMENT - Application environment
#   Container: backend
#   Options:  development, staging, production
#   Default:  development
ENVIRONMENT=development

# =============================================================================
# API KEYS (REQUIRED - At least one LLM provider)
# =============================================================================

# OPENAI_API_KEY - OpenAI API key
#   Container: backend
#   Required:  Yes (or another LLM provider)
#   Security: Never commit real keys
OPENAI_API_KEY=sk-your-openai-key

# ANTHROPIC_API_KEY - Anthropic Claude API key
#   Container: backend
#   Required:  Optional (alternative to OpenAI)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# GOOGLE_API_KEY - Google Gemini API key
#   Container: backend
#   Required:  Optional (alternative LLM)
# GOOGLE_API_KEY=your-google-key

# XAI_API_KEY - xAI Grok API key
#   Container: backend
#   Required:  Optional
# XAI_API_KEY=your-xai-key

# DEEPSEEK_API_KEY - DeepSeek API key
#   Container: backend
#   Required:  Optional
# DEEPSEEK_API_KEY=your-deepseek-key

# DEFAULT_PROVIDER - Default LLM provider
#   Container: backend
#   Options:  openai, anthropic, google, xai, deepseek, ollama
#   Default:  openai
DEFAULT_PROVIDER=openai

# =============================================================================
# API SECURITY (REQUIRED)
# =============================================================================

# API_ACCESS_KEY - Primary API authentication key
#   Container: backend
#   Required:  Yes
#   Security: Generate with: openssl rand -hex 32
#   Generate: docker compose run --rm backend openssl rand -hex 32
API_ACCESS_KEY=REPLACE_WITH_SECURE_RANDOM_KEY_32_CHARS

# API_ACCESS_KEY_SECONDARY - Secondary key for rotation
#   Container: backend
#   Required:  No (use for key rotation)
# API_ACCESS_KEY_SECONDARY=

# API_RATE_LIMIT_ENABLED - Enable rate limiting
#   Container: backend
#   Default:  true
# API_RATE_LIMIT_ENABLED=true

# API_RATE_LIMIT_RPM - Requests per minute limit
#   Container: backend
#   Default:  600
# API_RATE_LIMIT_RPM=600

# =============================================================================
# CORS CONFIGURATION
# =============================================================================

# CORS_ALLOW_ORIGINS - Allowed CORS origins (comma-separated)
#   Container: backend
#   Required:  Yes for production
#   Local:    * (allows all)
#   Production: Must be explicit (no wildcards)
#   Default:  * (development only)
CORS_ALLOW_ORIGINS=*

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================

# AUTH_JWT_ENABLED - Enable JWT-based authentication
#   Container: backend
#   Default:  false
# AUTH_JWT_ENABLED=false

# JWT_SECRET_KEY - Secret for JWT signing
#   Container: backend
#   Required:  Yes if AUTH_JWT_ENABLED=true
#   Security: Generate with: openssl rand -hex 32
# JWT_SECRET_KEY=REPLACE_WITH_SECURE_JWT_SECRET_32_CHARS

# JWT_ACCESS_TOKEN_EXPIRE_MINUTES - Access token lifetime
#   Container: backend
#   Default:  15
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# JWT_REFRESH_TOKEN_EXPIRE_DAYS - Refresh token lifetime
#   Container: backend
#   Default:  7
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================

# POSTGRES_USER - PostgreSQL username
#   Container: postgres
#   Required:  Yes
POSTGRES_USER=sprav_dev

# POSTGRES_PASSWORD - PostgreSQL password
#   Container: postgres
#   Required:  Yes
#   Security: Use a strong password
POSTGRES_PASSWORD=REPLACE_WITH_SECURE_POSTGRES_PASSWORD

# POSTGRES_DB - Database name
#   Container: postgres
#   Required:  Yes
POSTGRES_DB=realestate_db

# DATABASE_URL - Application database connection URL
#   Container: backend
#   Required:  Yes (auto-configured from POSTGRES_* vars)
#   Format:   postgresql+asyncpg://user:pass@host:5432/db
DATABASE_URL=postgresql+asyncpg://realestate:REPLACE_WITH_SECURE_POSTGRES_PASSWORD@postgres:5432/realestate_db

# DB_POOL_SIZE - Connection pool size
#   Container: backend
#   Default:  10
# DB_POOL_SIZE=10

# DB_MAX_OVERFLOW - Max overflow connections
#   Container: backend
#   Default:  20
# DB_MAX_OVERFLOW=20

# =============================================================================
# REDIS (Caching & Sessions)
# =============================================================================

# REDIS_URL - Redis connection URL
#   Container: backend
#   Default:  redis://redis:6379
REDIS_URL=redis://redis:6379

# CACHE_ENABLED - Enable response caching
#   Container: backend
#   Default:  true
# CACHE_ENABLED=true

# CACHE_TTL_SECONDS - Cache time-to-live
#   Container: backend
#   Default:  300
# CACHE_TTL_SECONDS=300

# CACHE_REDIS_URL - Redis URL for cache (defaults to REDIS_URL)
#   Container: backend
#   Default:  Uses REDIS_URL
# CACHE_REDIS_URL=redis://redis:6379

# =============================================================================
# OLLAMA (Local LLM - Optional)
# =============================================================================

# OLLAMA_API_BASE - Ollama API URL
#   Container: backend
#   Required:  Only if using Ollama
#   Docker:   http://ollama:11434 (with ollama service)
# OLLAMA_API_BASE=http://ollama:11434

# OLLAMA_DEFAULT_MODEL - Default Ollama model
#   Container: backend
#   Default:  llama3.2:3b
# OLLAMA_DEFAULT_MODEL=llama3.2:3b

# =============================================================================
# WEB SEARCH (Optional - SearXNG)
# =============================================================================

# SEARXNG_BASE_URL - SearXNG instance URL
#   Container: backend
#   Required:  Only if using web search
#   Docker:   http://searxng:8080 (with searxng service)
# SEARXNG_BASE_URL=http://searxng:8080

# SEARXNG_SECRET - SearXNG API secret
#   Container: backend
#   Required:  Only if SearXNG requires auth
#   Security: Generate with: openssl rand -hex 32
#   WARNING: Replace the default placeholder with a secure value for production!
SEARXNG_SECRET=REPLACE_WITH_SECURE_SEARXNG_SECRET

# INTERNET_ENABLED - Enable web search/fetch tools
#   Container: backend
#   Default:  false
# INTERNET_ENABLED=false

# =============================================================================
# EMAIL (Optional - SMTP)
# =============================================================================

# EMAIL_PROVIDER - Email provider
#   Container: backend
#   Options:  console (logs to stdout), smtp
#   Default:  console
# EMAIL_PROVIDER=console

# SMTP_HOST - SMTP server hostname
#   Container: backend
#   Required:  If EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com

# SMTP_PORT - SMTP server port
#   Container: backend
#   Default:  587
# SMTP_PORT=587

# SMTP_USERNAME - SMTP username
#   Container: backend
#   Required:  If EMAIL_PROVIDER=smtp
# SMTP_USERNAME=your.email@gmail.com

# SMTP_PASSWORD - SMTP password
#   Container: backend
#   Required:  If EMAIL_PROVIDER=smtp
#   Security: Use app-specific password for Gmail
# SMTP_PASSWORD=your-app-password

# EMAIL_FROM_ADDRESS - Default sender email
#   Container: backend
#   Default:  noreply@example.com
# EMAIL_FROM_ADDRESS=noreply@example.com

# =============================================================================
# PUSH NOTIFICATIONS (Optional - Task #63)
# =============================================================================

# VAPID_PUBLIC_KEY - VAPID public key for web push
#   Container: backend
#   Required:  Only if PUSH_ENABLED=true
#   Generate:  npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=

# VAPID_PRIVATE_KEY - VAPID private key
#   Container: backend
#   Required:  Only if PUSH_ENABLED=true
#   Security: Keep secret
# VAPID_PRIVATE_KEY=

# PUSH_ENABLED - Enable push notifications
#   Container: backend
#   Default:  false
# PUSH_ENABLED=false

# =============================================================================
# GOOGLE ROUTES API (Optional - Task #21)
# =============================================================================

# GOOGLE_ROUTES_API_KEY - Google Routes API key
#   Container: backend
#   Required:  For commute time analysis
#   Get:     https://developers.google.com/maps/routes
# GOOGLE_ROUTES_API_KEY=your-google-routes-api-key

# GOOGLE_ROUTES_ENABLED - Enable commute time analysis
#   Container: backend
#   Default:  true (if API key provided)
# GOOGLE_ROUTES_ENABLED=true

# =============================================================================
# E-SIGNATURE (Optional - Task #57)
# =============================================================================

# ESIGNATURE_PROVIDER - E-signature provider
#   Container: backend
#   Options:  hellosign, docusign
#   Default:  hellosign
# ESIGNATURE_PROVIDER=hellosign

# HELLOSIGN_API_KEY - HelloSign API key
#   Container: backend
#   Required:  If ESIGNATURE_ENABLED=true
#   Get:     https://app.hellosign.com
# HELLOSIGN_API_KEY=your-hellosign-api-key

# HELLOSIGN_WEBHOOK_SECRET - HelloSign webhook secret
#   Container: backend
#   Security: For webhook signature verification
# HELLOSIGN_WEBHOOK_SECRET=your-webhook-secret

# ESIGNATURE_ENABLED - Enable e-signature feature
#   Container: backend
#   Default:  false
# ESIGNATURE_ENABLED=false

# =============================================================================
# MCP CONNECTOR (Optional - Task #64)
# =============================================================================

# MCP_EDITION - MCP edition
#   Container: backend
#   Options:  community, pro, enterprise
#   Default:  community
# MCP_EDITION=community

# MCP_ALLOWLIST - Allowed MCP connectors (comma-separated)
#   Container: backend
#   Default:  empty (all community connectors)
# MCP_ALLOWLIST=

# MCP_ENABLED - Enable MCP functionality
#   Container: backend
#   Default:  true
# MCP_ENABLED=true

# =============================================================================
# CONTEXT WINDOW MANAGEMENT (Task #73)
# =============================================================================

# CONTEXT_MAX_UTILIZATION_PERCENT - Max context % before optimization
#   Container: backend
#   Default:  75
# CONTEXT_MAX_UTILIZATION_PERCENT=75

# CONTEXT_SLIDING_WINDOW_MESSAGES - Messages to keep in sliding window
#   Container: backend
#   Default:  50
# CONTEXT_SLIDING_WINDOW_MESSAGES=50

# CONTEXT_SUMMARIZATION_THRESHOLD_PERCENT - Threshold to trigger summarization
#   Container: backend
#   Default:  80
# CONTEXT_SUMMARIZATION_THRESHOLD_PERCENT=80

# CONTEXT_COMPRESSION_ENABLED - Enable content compression
#   Container: backend
#   Default:  true
# CONTEXT_COMPRESSION_ENABLED=true

# CONTEXT_METRICS_ENABLED - Enable context metrics logging
#   Container: backend
#   Default:  true
# CONTEXT_METRICS_ENABLED=true

# =============================================================================
# FRONTEND SETTINGS
# =============================================================================

# NEXT_PUBLIC_API_URL - API URL for frontend
#   Container: web (frontend)
#   Default:  /api/v1 (uses Next.js proxy)
# NEXT_PUBLIC_API_URL=/api/v1

# BACKEND_API_URL - Backend URL for Next.js API proxy
#   Container: web (frontend)
#   Default:  http://backend:8000/api/v1
BACKEND_API_URL=http://backend:8000/api/v1

# =============================================================================
# MONITORING (Optional)
# =============================================================================

# METRICS_ENABLED - Enable application metrics
#   Container: backend
#   Default:  true
# METRICS_ENABLED=true

# PROMETHEUS_ENABLED - Enable Prometheus export
#   Container: backend
#   Default:  false
# PROMETHEUS_ENABLED=false

# =============================================================================
# SENTRY ERROR TRACKING (Optional)
# =============================================================================

# SENTRY_DSN - Sentry Data Source Name
#   Container: backend
#   Required:  Only if using Sentry
#   Get:     https://sentry.io → Project Settings → DSN
# SENTRY_DSN=https://xxx@sentry.io/xxx

# SENTRY_TRACES_SAMPLE_RATE - Performance trace sample rate (0.0-1.0)
#   Container: backend
#   Default:  0.1 (10% of transactions)
# SENTRY_TRACES_SAMPLE_RATE=0.1

# SENTRY_ENVIRONMENT - Override environment name in Sentry
#   Container: backend
#   Default:  Uses ENVIRONMENT variable
# SENTRY_ENVIRONMENT=production

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================

# SESSION_TYPE - Session storage backend
#   Container: backend
#   Options:  memory, redis, file
#   Default:  memory
#   Production: redis (required for multi-instance)
# SESSION_TYPE=memory

# SESSION_REDIS_URL - Redis URL for sessions
#   Container: backend
#   Default:  Uses REDIS_URL
# SESSION_REDIS_URL=redis://redis:6379

# =============================================================================
# SERVICE PORTS (Docker internal)
# =============================================================================

# BACKEND_PORT - Backend service port
#   Container: backend
#   Default:  8000
BACKEND_PORT=8000

# WEB_PORT - Frontend service port
#   Container: web
#   Default:  3000
WEB_PORT=3000

# POSTGRES_PORT - PostgreSQL port (host mapping)
#   Container: postgres
#   Default:  5432
POSTGRES_PORT=5432

# REDIS_PORT - Redis port (host mapping)
#   Container: redis
#   Default:  6379
REDIS_PORT=6379
