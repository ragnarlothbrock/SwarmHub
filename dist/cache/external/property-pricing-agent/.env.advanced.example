# Advanced Environment Variables
# Copy relevant entries to your .env file. Only change these if you know what you're doing.
# For common variables, see .env.example.

# =============================================================================
# API SECURITY — TUNING
# =============================================================================

# API_ACCESS_KEYS=new-key,old-key  # Multiple keys for zero-downtime rotation
# API_ACCESS_KEY_SECONDARY=secondary-key-here
# API_RATE_LIMIT_ENABLED=true
# API_RATE_LIMIT_RPM=600

# =============================================================================
# ACCOUNT LOCKOUT
# =============================================================================

# AUTH_LOCKOUT_MAX_ATTEMPTS=5
# AUTH_LOCKOUT_DURATION_MINUTES=15

# =============================================================================
# DATABASE POOL
# =============================================================================

# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT_SECONDS=30
# DB_POOL_RECYCLE_SECONDS=3600

# =============================================================================
# LLM TIMEOUTS
# =============================================================================

# LLM_REQUEST_TIMEOUT_SECONDS=120
# LLM_CONNECT_TIMEOUT_SECONDS=30

# =============================================================================
# WEB SEARCH & FETCH
# =============================================================================

# SEARXNG_URL=
# WEB_SEARCH_MAX_RESULTS=5
# WEB_FETCH_TIMEOUT_SECONDS=10
# WEB_FETCH_MAX_BYTES=300000
# WEB_ALLOWLIST_DOMAINS=

# =============================================================================
# CHAT SOURCES
# =============================================================================

# CHAT_SOURCES_MAX_ITEMS=5
# CHAT_SOURCE_CONTENT_MAX_CHARS=2000
# CHAT_SOURCES_MAX_TOTAL_BYTES=20000

# =============================================================================
# RAG SETTINGS
# =============================================================================

# RAG_MAX_FILES=10
# RAG_MAX_FILE_BYTES=10485760
# RAG_MAX_TOTAL_BYTES=26214400

# =============================================================================
# REQUEST SIZE LIMITS
# =============================================================================

# REQUEST_MAX_BODY_SIZE_MB=10
# REQUEST_MAX_UPLOAD_SIZE_MB=25

# =============================================================================
# DATA SETTINGS
# =============================================================================

# VALUATION_MODE=simple
# LEGAL_CHECK_MODE=basic
# CRM_WEBHOOK_URL=
# DEFAULT_DATASETS=

# =============================================================================
# CACHE TUNING
# =============================================================================

# CACHE_PREFIX=api_cache
# CACHE_MAX_MEMORY_MB=100
# CACHE_STALE_WHILE_REVALIDATE=false

# =============================================================================
# METRICS PATH
# =============================================================================

# METRICS_PATH=/metrics

# =============================================================================
# UPTIME MONITOR
# =============================================================================

# UPTIME_MONITOR_ENABLED=false
# UPTIME_MONITOR_HEALTH_URL=http://localhost:8000/health
# UPTIME_MONITOR_EMAIL_TO=ops@example.com
# UPTIME_MONITOR_INTERVAL=60
# UPTIME_MONITOR_FAIL_THRESHOLD=3
# UPTIME_MONITOR_COOLDOWN_SECONDS=1800

# =============================================================================
# E-SIGNATURE TUNING
# =============================================================================

# ESIGNATURE_DEFAULT_EXPIRY_DAYS=30
# ESIGNATURE_REMINDER_ENABLED=true

# =============================================================================
# MCP TUNING
# =============================================================================

# MCP_DEFAULT_TIMEOUT_SECONDS=30
# MCP_POOL_MAX_CONNECTIONS=10
# MCP_DATA_MINIMIZATION_ENABLED=true

# =============================================================================
# CONTEXT WINDOW MANAGEMENT
# =============================================================================

# CONTEXT_MAX_UTILIZATION_PERCENT=75
# CONTEXT_SLIDING_WINDOW_MESSAGES=50
# CONTEXT_SUMMARIZATION_THRESHOLD_PERCENT=80
# CONTEXT_COMPRESSION_ENABLED=true
# CONTEXT_METRICS_ENABLED=true
# CONTEXT_PRIORITY_SYSTEM_WEIGHT=1.0
# CONTEXT_PRIORITY_RECENT_WEIGHT=0.8

# =============================================================================
# STREAMING
# =============================================================================

# STREAM_HEARTBEAT_INTERVAL_SECONDS=15
# STREAM_TIMEOUT_SECONDS=300
# STREAM_BACKOFF_INITIAL_MS=1000
# STREAM_BACKOFF_MAX_MS=30000
# STREAM_BACKOFF_MULTIPLIER=2.0
# STREAM_MAX_RETRIES=5
# STREAM_METRICS_ENABLED=true
# STREAM_DEGRADATION_THRESHOLD=3

# =============================================================================
# SENTRY
# =============================================================================

# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=development
