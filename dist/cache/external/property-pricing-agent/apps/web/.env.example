# Frontend (Next.js) Environment Variables
# Copy this file to .env.local for local development
#
# Documentation Legend:
#   Local:    Settings for local development (localhost:3800)
#   GitHub:   Which GitHub Actions secret to configure
#   Vercel:   Where to set in Vercel dashboard
#   Security: Notes about exposing to browser
#
# IMPORTANT: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
#            Never put secrets in public variables!

# =============================================================================
# PUBLIC ENVIRONMENT VARIABLES (Client-Side)
# These are bundled into the JavaScript and visible in the browser.
# ⚠️ SECURITY: Do NOT put secrets, API keys, or sensitive data here!
# =============================================================================

# NEXT_PUBLIC_API_URL - API endpoint path for client-side requests
#   Description: Path prefix for all API calls from the browser
#   Local:    /api/v1 (uses Next.js API proxy)
#   Vercel:   /api/v1 (same - proxy handles routing)
#   Docker:   /api/v1
#   Default:  /api/v1
#   Security: Public - only contains path, not full URL
NEXT_PUBLIC_API_URL=/api/v1

# NEXT_PUBLIC_APP_NAME - Application name shown in UI
#   Default:  AI Real Estate Assistant
# NEXT_PUBLIC_APP_NAME=AI Real Estate Assistant

# NEXT_PUBLIC_APP_URL - Public URL of the application
#   Local:    http://localhost:3800
#   Vercel:   https://your-app.vercel.app
#   Docker:   http://localhost:3082
#   Default:  http://localhost:3800
# NEXT_PUBLIC_APP_URL=http://localhost:3800

# NEXT_PUBLIC_MAPBOX_TOKEN - Mapbox public access token for maps
#   Description: Used for enhanced mapping features in property search
#   Local:    Optional - get from https://account.mapbox.com/
#   Vercel:   Environment Variables → NEXT_PUBLIC_MAPBOX_TOKEN
#   Default:  empty (uses fallback map)
#   Security: Public token (has restrictions in Mapbox dashboard)
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijo...

# NEXT_PUBLIC_ANALYTICS_ID - Analytics tracking ID (e.g., Google Analytics)
#   Local:    empty (no tracking in dev)
#   Vercel:   Environment Variables → NEXT_PUBLIC_ANALYTICS_ID
#   Default:  empty
# NEXT_PUBLIC_ANALYTICS_ID=G-XXXXXXXXXX

# NEXT_PUBLIC_FEATURE_FLAGS - Client-side feature flags
#   Format:   comma-separated list of enabled features
#   Example:  chat,maps,notifications
#   Default:  all features enabled
# NEXT_PUBLIC_FEATURE_FLAGS=chat,maps

# NEXT_PUBLIC_DEMO_MODE - Enable demo mode (bypass auth for all routes)
#   Set to 'true' on staging/showcase deployments
#   Default: false
# NEXT_PUBLIC_DEMO_MODE=true

# =============================================================================
# SERVER-SIDE ENVIRONMENT VARIABLES (Private)
# These are ONLY used on the server and NOT exposed to the browser.
# Safe to put secrets here.
# =============================================================================

# BACKEND_API_URL - Backend API URL for Next.js server-side proxy
#   Description: Where the Next.js API routes forward requests
#   Local:    http://localhost:8001/api/v1 (local FastAPI server)
#   Vercel:   Use Vercel's internal routing or external backend URL
#             Preview: https://your-backend-preview.vercel.app/api/v1
#             Production: https://your-backend-production.com/api/v1
#   Docker:   http://backend:8000/api/v1 (Docker network)
#   VPS:      http://localhost:8000/api/v1 (same server)
#   Default:  http://localhost:8001/api/v1
#   Note:     Port may vary - check .env.ports for auto-assigned port
BACKEND_API_URL=http://localhost:8001/api/v1

# API_ACCESS_KEY - API key for backend authentication
#   Description: Must match the backend's API_ACCESS_KEY
#   Local:    Generate with: openssl rand -hex 32
#             Must match apps/api/.env API_ACCESS_KEY
#   GitHub:   Secret: API_ACCESS_KEY
#   Vercel:   Environment Variables → API_ACCESS_KEY
#   Docker:   Set in deploy/compose/.env (same as backend)
#   Security: Never commit real keys to git
#   Note:     This is server-side only, not exposed to browser
API_ACCESS_KEY=your-generated-api-key-here

# API_ACCESS_KEYS - Multiple API keys for rotation (comma-separated)
#   Description: Alternative to single API_ACCESS_KEY for zero-downtime rotation
#   Format:   new-key,old-key
#   Default:  Uses API_ACCESS_KEY if not set
# API_ACCESS_KEYS=new-key,old-key

# =============================================================================
# OPTIONAL: EXTERNAL SERVICES (Server-Side)
# =============================================================================

# NEXT_PUBLIC_SENTRY_DSN - Sentry error tracking DSN
#   Description: Enable error reporting to Sentry
#   Local:    empty (no reporting in dev)
#   Vercel:   Environment Variables → NEXT_PUBLIC_SENTRY_DSN
#   Default:  empty
#   Note:     Public DSN is safe to expose (client-side error reporting)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# SENTRY_AUTH_TOKEN - Sentry auth token for source maps
#   Description: For uploading source maps to Sentry
#   GitHub:   Secret: SENTRY_AUTH_TOKEN
#   Vercel:   Environment Variables → SENTRY_AUTH_TOKEN
#   Security: Keep secret - not exposed to browser
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# =============================================================================
# OPTIONAL: AUTHENTICATION (Server-Side)
# =============================================================================

# NEXTAUTH_SECRET - NextAuth.js secret for JWT signing
#   Description: Required if using NextAuth for authentication
#   Local:    Generate with: openssl rand -hex 32
#   GitHub:   Secret: NEXTAUTH_SECRET
#   Vercel:   Environment Variables → NEXTAUTH_SECRET
#   Security: Keep secret
# NEXTAUTH_SECRET=your-nextauth-secret

# NEXTAUTH_URL - NextAuth.js callback URL
#   Local:    http://localhost:3800
#   Vercel:   https://your-app.vercel.app
#   Default:  http://localhost:3800
# NEXTAUTH_URL=http://localhost:3800

# =============================================================================
# OPTIONAL: REDIS (Server-Side)
# =============================================================================

# REDIS_URL - Redis connection for session storage or caching
#   Local:    empty (not required)
#   Docker:   redis://redis:6379
#   VPS:      redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# =============================================================================
# BUILD-TIME VARIABLES
# These are evaluated at build time, not runtime.
# =============================================================================

# NEXT_BUILD_ID - Build identifier for version tracking
#   Default:  Git commit SHA (auto)
# NEXT_BUILD_ID=

# NEXT_BUILD_TIME - Build timestamp
#   Default:  Build time (auto)
# NEXT_BUILD_TIME=
