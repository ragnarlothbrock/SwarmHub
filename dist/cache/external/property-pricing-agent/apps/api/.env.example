# AI Real Estate Assistant - Backend Environment Variables
# Copy this file to .env and fill in your values
# Generate secrets: openssl rand -hex 32

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development

# =============================================================================
# LLM PROVIDER API KEYS (at least one required)
# =============================================================================
# Single key per provider (legacy format)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
XAI_API_KEY=...
DEEPSEEK_API_KEY=...
ZHIPUAI_API_KEY=...
MOONSHOT_API_KEY=...

# Multi-key per provider (for failover) - CSV format
# Uncomment to enable automatic key rotation when one hits rate limits
# OPENAI_API_KEYS=sk-key1,sk-key2,sk-key3
# ANTHROPIC_API_KEYS=sk-ant-key1,sk-ant-key2
# GOOGLE_API_KEYS=key1,key2

# Default LLM provider (openai, anthropic, google, xai, deepseek, zai, moonshot, ollama)
DEFAULT_PROVIDER=openai

# =============================================================================
# MULTI-PROVIDER FAILOVER (optional)
# =============================================================================
# Enable multi-key and multi-provider failover
# ENABLE_MULTI_KEY_FALLBACK=true

# Key rotation strategy: round-robin, random, priority
# KEY_ROTATION_STRATEGY=round-robin

# Number of failures before switching to next key
# KEY_FAILURE_THRESHOLD=5

# Provider fallback order (comma-separated)
# PROVIDER_PRIORITY_ORDER=openai,anthropic,google,deepseek,zai

# Ollama (local LLM - optional)
# OLLAMA_API_BASE=http://localhost:11434
# OLLAMA_DEFAULT_MODEL=llama3.2:3b

# =============================================================================
# API SECURITY (REQUIRED)
# =============================================================================
# Generate: openssl rand -hex 32
API_ACCESS_KEY=your-generated-api-key-here

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Local: * or http://localhost:3800
# Production: REQUIRED - explicit list, no wildcards
CORS_ALLOW_ORIGINS=http://localhost:3800

# =============================================================================
# JWT AUTHENTICATION (optional)
# =============================================================================
# AUTH_JWT_ENABLED=true
# JWT_SECRET_KEY=your-jwt-secret-key-here
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# DATABASE
# =============================================================================
# SQLite (local dev): sqlite+aiosqlite:///./data/auth.db
# PostgreSQL (production): postgresql+asyncpg://user:password@localhost:5432/realestate
DATABASE_URL=sqlite+aiosqlite:///./data/auth.db

# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# =============================================================================
# REDIS (optional - for caching)
# =============================================================================
# REDIS_URL=redis://localhost:6379

# =============================================================================
# SENTRY (optional - error tracking & APM, Task #56)
# =============================================================================
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_TRACES_SAMPLE_RATE=0.2
# SENTRY_ENVIRONMENT=production
# OAUTH (optional)
# =============================================================================
# AUTH_OAUTH_GOOGLE_ENABLED=false
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# GOOGLE_REDIRECT_URI=http://localhost:3800/api/v1/auth/oauth/callback

# =============================================================================
# EMAIL (optional)
# =============================================================================
# EMAIL_PROVIDER=console
# EMAIL_FROM_ADDRESS=noreply@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your.email@gmail.com
# SMTP_PASSWORD=your-app-specific-password

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# AUTH_REGISTRATION_ENABLED=true
# AUTH_EMAIL_VERIFICATION_REQUIRED=true
# AUTH_LOCKOUT_MAX_ATTEMPTS=5
# AUTH_LOCKOUT_DURATION_MINUTES=15

# =============================================================================
# DEMO MODE (for public staging / showcase)
# =============================================================================
# DEMO_MODE=true

# =============================================================================
# RATE LIMITING
# =============================================================================
# API_RATE_LIMIT_ENABLED=true
# API_RATE_LIMIT_RPM=600
