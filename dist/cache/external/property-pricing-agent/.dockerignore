# Git files
.git
.gitignore
.gitattributes

# Python cache
__pycache__
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments (match at any depth)
**/venv/
**/env/
**/ENV/
**/.venv
**/.venv*/
**/.venv_ci/

# Type checkers and linters cache
**/.mypy_cache/
**/.ruff_cache/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
**/.pytest_cache/
.coverage
htmlcov/
.tox/
**/tests/
*.test

# Documentation
docs/
*.md
!README.md
LICENSE

# Local data (will be mounted as volumes)
chroma_db/
.preferences/
.notifications/
.sessions/
dataset/

# Environment files (sensitive)
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# Temporary files
*.tmp
*.bak
*.swp

# OS files
Thumbs.db
.DS_Store

# Development scripts
run_tests.sh
test_*.sh
*.ps1

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Other
*.sqlite
*.db

# Node modules — frontend Dockerfile uses npm ci, doesn't need host node_modules
**/node_modules/

# Private non-committed materials (exclude from images)
private/

# Trae + IDE history (exclude from images)
.history/
.trae/

# Frontend build artifacts (source is needed for frontend Docker build)
.next/
next-env.d.ts
frontend/

# Local artifacts
artifacts/

# Deploy directory (not needed in backend image)
deploy/

# Apps directories except api
apps/database/

# Additional exclusions
# Note: apps/api/data/ contains Python source code, must be included
data/
!apps/api/data/
**/audit/*.csv
uv.lock
coverage.xml
tmp/
dummy/

# Root package files not needed in images
package.json
package-lock.json
