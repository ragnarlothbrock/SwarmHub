# AI Real Estate Assistant - Environment Variables
# Copy this file to .env and fill in your values.
#
# Variables marked [Required] must be set for the app to start.
# Variables marked [Optional] have sensible defaults.
# For advanced tuning (timeouts, pool sizes, context windows), see .env.advanced.example.
#
# Frontend variables are in apps/web/.env.example.

# =============================================================================
# REQUIRED
# =============================================================================

# [Required] Application environment: development | production
ENVIRONMENT=development

# [Required] API key for backend authentication
# Generate: openssl rand -hex 32
API_ACCESS_KEY=your-generated-api-key-here

# =============================================================================
# LLM PROVIDERS (at least one required)
# =============================================================================

# [Optional] OpenAI GPT-4/GPT-4o API key
OPENAI_API_KEY=sk-...

# [Optional] Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# [Optional] Google Gemini API key
GOOGLE_API_KEY=...

# [Optional] xAI Grok API key
XAI_API_KEY=...

# [Optional] DeepSeek API key
DEEPSEEK_API_KEY=...

# [Optional] ZAI (Zhipu AI) API key — 95%+ cheaper than OpenAI
ZAI_API_KEY=...

# [Optional] Moonshot AI (Kimi) API key — 128K context
MOONSHOT_API_KEY=...

# [Optional] OpenCode Go API key — curated open coding models (GLM, Kimi, DeepSeek, Qwen)
# OPENCODE_API_KEY=...

# [Optional] OpenRouter API key — unified access to 400+ models including free ones
OPENROUTER_API_KEY=...

# [Optional] Default LLM provider: openai | anthropic | google | xai | deepseek | openrouter | zai | moonshot | opencode | ollama
# DEFAULT_PROVIDER=openai

# [Optional] Override default model for provider
# DEFAULT_MODEL=gpt-4o

# [Optional] Ollama for local LLM (requires OLLAMA_BASE_URL)
# OLLAMA_DEFAULT_MODEL=llama3.2:3b
# OLLAMA_API_BASE=http://localhost:11434

# =============================================================================
# CORS
# =============================================================================

# [Optional] CORS origins (comma-separated). Use * for dev, explicit URLs for prod.
# Default: *
# CORS_ALLOW_ORIGINS=http://localhost:3000

# =============================================================================
# FRONTEND
# =============================================================================

# [Optional] Frontend URL for email links and CORS
# Default: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# [Optional] Backend API URL (for Next.js proxy, not needed in Vercel)
# Default: http://localhost:8000/api/v1
# BACKEND_API_URL=http://localhost:8000/api/v1

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================

# [Optional] Enable JWT-based user authentication
# Default: false
# AUTH_JWT_ENABLED=true

# [Required if JWT enabled] Secret key for JWT signing
# Generate: openssl rand -hex 32
# JWT_SECRET_KEY=your-jwt-secret-key-here

# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# OAUTH — GOOGLE (Optional)
# =============================================================================

# AUTH_OAUTH_GOOGLE_ENABLED=false
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/oauth/callback

# =============================================================================
# OAUTH — APPLE (Optional)
# =============================================================================

# AUTH_OAUTH_APPLE_ENABLED=false
# APPLE_CLIENT_ID=
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY_PATH=

# =============================================================================
# DATABASE
# =============================================================================

# [Optional] Database URL. Default: SQLite at ./data/auth.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/realestate
# DATABASE_URL=sqlite+aiosqlite:///./data/auth.db
# DATABASE_URL=postgresql+asyncpg://realestate:realestate@postgres:5432/realestate

# PostgreSQL connection (used with docker compose --profile postgres)
# POSTGRES_USER=realestate
# POSTGRES_PASSWORD=realestate
# POSTGRES_DB=realestate
# POSTGRES_PORT=5432

# =============================================================================
# EMAIL
# =============================================================================

# [Optional] Email provider: console (dev) | smtp (production)
# Default: console
# EMAIL_PROVIDER=console
# EMAIL_FROM_ADDRESS=noreply@example.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# AUTH_REGISTRATION_ENABLED=true
# AUTH_EMAIL_VERIFICATION_REQUIRED=true
# INTERNET_ENABLED=false
# DATA_ENRICHMENT_ENABLED=false

# =============================================================================
# PUSH NOTIFICATIONS
# =============================================================================

# PUSH_ENABLED=false
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:noreply@yourdomain.com

# =============================================================================
# E-SIGNATURE INTEGRATION
# =============================================================================

# ESIGNATURE_ENABLED=false
# ESIGNATURE_PROVIDER=hellosign
# HELLOSIGN_API_KEY=
# HELLOSIGN_CLIENT_ID=
# HELLOSIGN_WEBHOOK_SECRET=

# =============================================================================
# GOOGLE ROUTES API (Commute Time Analysis)
# =============================================================================

# GOOGLE_ROUTES_API_KEY=
# GOOGLE_ROUTES_ENABLED=true

# =============================================================================
# MCP CONNECTOR SETTINGS
# =============================================================================

# MCP_ENABLED=true
# MCP_EDITION=community
# MCP_ALLOWLIST=

# =============================================================================
# MCP AUDIT LOGGING
# =============================================================================

# MCP_AUDIT_LOGGING_ENABLED=true
# MCP_AUDIT_LOG_DIR=logs/mcp_audit
# MCP_AUDIT_RETENTION_DAYS=30

# =============================================================================
# VECTOR STORE
# =============================================================================

# CHROMA_PERSIST_DIR=./vector_store/chroma

# =============================================================================
# CACHING
# =============================================================================

# CACHE_ENABLED=true
# CACHE_TTL_SECONDS=300
# CACHE_REDIS_URL=redis://localhost:6379

# =============================================================================
# REDIS
# =============================================================================

# REDIS_URL=redis://localhost:6379

# =============================================================================
# METRICS & MONITORING
# =============================================================================

# METRICS_ENABLED=true
# PROMETHEUS_ENABLED=false
# SENTRY_DSN=
