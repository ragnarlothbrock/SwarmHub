# Standard EOL configuration — LF everywhere, CRLF only for Windows scripts
* text=auto eol=lf
# Windows-only: CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf
*.psm1      text eol=crlf
# Linux deployment: LF (explicit for safety)
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile  text eol=lf
docker-compose*.yml text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
# Source code: LF
*.py        text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.vue       text eol=lf
*.rs        text eol=lf
*.toml      text eol=lf
# Config/data: LF
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.xml       text eol=lf
*.env*      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
# Git metadata
.gitattributes text eol=lf
.gitignore     text eol=lf
.gitmodules    text eol=lf
# Binary: never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
*.dll binary
*.so binary
*.pyd binary
*.sqlite3 binary
*.db binary
*.node binary
# CSV files tracked by Git LFS
#*.csv filter=lfs diff=lfs merge=lfs -text
# No LFS tracking — all binary files committed directly
